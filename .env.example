# ── Gemini ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Set this to your ngrok URL when running locally (e.g. https://abc123.ngrok.io)
TELEGRAM_WEBHOOK_URL=https://your-ngrok-url.ngrok.io

# ── Tavily (Web Search) ────────────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=anton
POSTGRES_PASSWORD=antonpass
POSTGRES_DB=antondb
DATABASE_URL=postgresql+asyncpg://anton:antonpass@localhost:5432/antondb

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── LangSmith (optional — enables full tracing of all LLM calls) ──────────────
# Sign up free at smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=anton

# ── App ────────────────────────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_random_secret_key
ENVIRONMENT=development
